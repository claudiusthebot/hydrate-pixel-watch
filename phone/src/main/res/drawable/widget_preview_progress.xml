<?xml version="1.0" encoding="utf-8"?>
<!--
    Layered drawable that draws a track + a 62 %-filled bar. Preview-only:
    the runtime widget renders the bar via two stacked Glance Boxes so the
    fill width tracks live state.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?android:attr/colorControlHighlight" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <item android:width="140dp" android:gravity="start|center_vertical">
        <shape android:shape="rectangle">
            <solid android:color="?android:attr/colorAccent" />
            <corners android:radius="3dp" />
        </shape>
    </item>
</layer-list>
